// chargev-admin Prisma schema
// 자세한 데이터 모델 설명은 docs/ERD.md 참조.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────

enum SystemRole {
  main_admin
  normal_admin
  partner_admin
}

enum ScopeRole {
  owner
  member
  viewer
}

enum ClaimStatus {
  pending
  approved
  rejected
  info_required
}

enum NotifyChannel {
  email
  sms
  kakao
  inapp
}

enum NotifyType {
  fault_alert
  settlement
  contract_expiry
  inspection
  approval_result
  invite
  announcement
}

enum TicketCategory {
  fault
  maintenance_request
  inquiry
  other
}

enum TicketPriority {
  low
  normal
  high
  urgent
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
  cancelled
}

enum InspectionStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum InspectionResult {
  pass
  fail
  needs_repair
}

enum NoticeKind {
  maintenance
  feature
  announcement
  security
  event
}

enum ResourceCategory {
  manual
  form
  guide
  contract_template
  marketing
  other
}

// ─── User & Auth ──────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String
  phone        String
  businessNo   String?    @map("business_no")
  role         SystemRole

  ci String?
  di String?

  emailVerifiedAt    DateTime? @map("email_verified_at")
  phoneVerifiedAt    DateTime? @map("phone_verified_at")
  lastLoginAt        DateTime? @map("last_login_at")
  lockedUntil        DateTime? @map("locked_until")
  failedLoginCount   Int       @default(0) @map("failed_login_count")
  passwordChangedAt  DateTime  @default(now()) @map("password_changed_at")
  mustChangePassword Boolean   @default(false) @map("must_change_password")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts            Account[]                @relation("UserAccounts")
  invitedAccounts     Account[]                @relation("InvitedAccounts")
  sessions            Session[]
  twoFactor           TwoFactorAuth?
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  usedInviteToken     InviteToken?             @relation("InviteUsedBy")
  createdInviteTokens InviteToken[]            @relation("InviteCreatedBy")
  claimRequests       ClaimRequest[]           @relation("ClaimSubmitter")
  reviewedClaims      ClaimRequest[]           @relation("ClaimReviewer")
  notifyPreferences   NotificationPreference[]
  reportedTickets     MaintenanceTicket[]      @relation("TicketReporter")
  assignedTickets     MaintenanceTicket[]      @relation("TicketAssignee")
  inspections         Inspection[]             @relation("InspectionInspector")
  extraPermissions    UserPermission[]         @relation("UserPermissionUser")
  grantedPermissions  UserPermission[]         @relation("UserPermissionGrantedBy")

  @@index([businessNo])
  @@index([phone])
  @@map("users")
}

model Account {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  stationId       String    @map("station_id")
  scopeRole       ScopeRole @map("scope_role")
  invitedByUserId String?   @map("invited_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  user      User  @relation("UserAccounts", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User? @relation("InvitedAccounts", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, stationId])
  @@index([stationId])
  @@map("accounts")
}

model Session {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  tokenHash    String    @unique @map("token_hash")
  ipAddress    String    @map("ip_address")
  userAgent    String    @map("user_agent")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  lastActiveAt DateTime  @default(now()) @map("last_active_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("sessions")
}

model TwoFactorAuth {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  secret      String // encrypted
  backupCodes Json      @map("backup_codes") // hashed strings[]
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_auth")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Onboarding ───────────────────────────────────────────────────────

model InviteToken {
  id              String    @id @default(uuid())
  tokenHash       String    @unique @map("token_hash")
  businessNo      String    @map("business_no")
  phone           String
  email           String?
  stationIds      Json      @map("station_ids") // string[]
  expiresAt       DateTime  @map("expires_at")
  usedAt          DateTime? @map("used_at")
  usedByUserId    String?   @unique @map("used_by_user_id")
  createdByUserId String    @map("created_by_user_id")
  remindersSent   Int       @default(0) @map("reminders_sent")
  lastReminderAt  DateTime? @map("last_reminder_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  usedBy    User? @relation("InviteUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)
  createdBy User  @relation("InviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([businessNo, phone])
  @@index([expiresAt])
  @@map("invite_tokens")
}

model ClaimRequest {
  id               String      @id @default(uuid())
  userId           String      @map("user_id")
  stationId        String      @map("station_id")
  businessNo       String      @map("business_no")
  evidenceFileKeys Json        @map("evidence_file_keys") // string[]
  status           ClaimStatus @default(pending)
  reviewedByUserId String?     @map("reviewed_by_user_id")
  reviewedAt       DateTime?   @map("reviewed_at")
  reviewNote       String?     @map("review_note") @db.Text
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user       User  @relation("ClaimSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ClaimReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([stationId])
  @@map("claim_requests")
}

// ─── Audit & Preferences ──────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  before       Json?
  after        Json?
  ipAddress    String   @map("ip_address")
  userAgent    String   @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([resourceType, resourceId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model NotificationPreference {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  channel   NotifyChannel
  type      NotifyType
  enabled   Boolean       @default(true)
  updatedAt DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, type])
  @@map("notification_preferences")
}

// ─── Maintenance ───────────────────────────────────────────────────────

model MaintenanceTicket {
  id              String          @id @default(uuid())
  stationId       String          @map("station_id")
  chargerId       String?         @map("charger_id")
  title           String
  description     String          @db.Text
  category        TicketCategory  @default(fault)
  priority        TicketPriority  @default(normal)
  status          TicketStatus    @default(open)
  reporterUserId  String          @map("reporter_user_id")
  assigneeUserId  String?         @map("assignee_user_id")
  resolution      String?         @db.Text
  resolvedAt      DateTime?       @map("resolved_at")
  closedAt        DateTime?       @map("closed_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  reporter User  @relation("TicketReporter", fields: [reporterUserId], references: [id], onDelete: Restrict)
  assignee User? @relation("TicketAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@index([stationId, status])
  @@index([status, priority, createdAt])
  @@index([reporterUserId])
  @@index([assigneeUserId])
  @@map("maintenance_tickets")
}

model Inspection {
  id               String             @id @default(uuid())
  stationId        String             @map("station_id")
  chargerId        String?            @map("charger_id")
  inspectorUserId  String?            @map("inspector_user_id")
  scheduledAt      DateTime           @map("scheduled_at")
  performedAt      DateTime?          @map("performed_at")
  status           InspectionStatus   @default(scheduled)
  result           InspectionResult?
  notes            String?            @db.Text
  nextScheduledAt  DateTime?          @map("next_scheduled_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  inspector User? @relation("InspectionInspector", fields: [inspectorUserId], references: [id], onDelete: SetNull)

  @@index([stationId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("inspections")
}

// ─── Customer service ──────────────────────────────────────────────────

model Notice {
  id           String     @id @default(uuid())
  kind         NoticeKind @default(announcement)
  title        String
  body         String?    @db.Text
  publishedAt  DateTime   @default(now()) @map("published_at")
  pinned       Boolean    @default(false)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([pinned, publishedAt])
  @@index([kind, publishedAt])
  @@map("notices")
}

model Resource {
  id           String           @id @default(uuid())
  category     ResourceCategory @default(other)
  title        String
  description  String?          @db.Text
  fileKey      String?          @map("file_key")
  fileName     String?          @map("file_name")
  externalUrl  String?          @map("external_url")
  publishedAt  DateTime         @default(now()) @map("published_at")
  pinned       Boolean          @default(false)
  downloadCount Int             @default(0) @map("download_count")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([category, publishedAt])
  @@index([pinned, publishedAt])
  @@map("resources")
}

// ─── Station Group (정산 그룹과 별개의 분류,태그 용도) ────────────────

model StationGroup {
  id          String                  @id @default(uuid())
  name        String                  @unique
  description String?                 @db.Text
  color       String                  @default("#1570EF")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  members     StationGroupMember[]

  @@map("station_groups")
}

model StationGroupMember {
  id          String       @id @default(uuid())
  groupId     String       @map("group_id")
  stationId   String       @map("station_id")
  createdAt   DateTime     @default(now()) @map("created_at")

  group       StationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, stationId])
  @@index([stationId])
  @@map("station_group_members")
}

// ─── Permission (role 템플릿 위에 사용자별 추가 grant) ─────────────

model UserPermission {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  permission      String   // e.g. 'view:revenue', 'manage:notices'
  grantedAt       DateTime @default(now()) @map("granted_at")
  grantedByUserId String?  @map("granted_by_user_id")

  user      User  @relation("UserPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("UserPermissionGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, permission])
  @@index([permission])
  @@map("user_permissions")
}
