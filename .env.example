# ─── Database ─────────────────────────────────────────────────────────
# PostgreSQL connection string. 로컬 개발 시:
#   docker run -d --name chargev-pg -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16
DATABASE_URL="postgresql://postgres:dev@localhost:5432/chargev?schema=public"

# ─── Adapters (mock <-> real) ─────────────────────────────────────────
# 운영 전환 시 mock 대신 실제 구현체로 변경
ADAPTER_AUTH=mock              # mock | nice
ADAPTER_STATION=mock           # mock | company-api
ADAPTER_CONTRACT=mock          # mock | salesforce
ADAPTER_STORAGE=mock           # mock | nas | s3
ADAPTER_NOTIFICATION=console   # console | bizmessage
ADAPTER_NOTICE=mock            # mock | company-cms (사내 공지 시스템)

# ─── Auth & Session ───────────────────────────────────────────────────
# 세션 토큰 hashing key (32 bytes hex). 운영 전환 시 반드시 교체.
SESSION_SECRET="dev-only-secret-replace-in-production"
# TOTP secret encryption key
TOTP_ENCRYPTION_KEY="dev-only-key-replace-in-production"

# ─── External services (운영 전환 시 채움) ─────────────────────────────
# NICE_CLIENT_ID=
# NICE_CLIENT_SECRET=
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# BIZMESSAGE_API_KEY=
